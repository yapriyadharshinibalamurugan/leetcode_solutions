#include <stdio.h>
#include <limits.h>

int main() {
    int N, curr;
    scanf("%d", &N);

    int fmax = INT_MIN;
    int smax = INT_MIN;

    for (int i = 0; i < N; i++) {
        scanf("%d", &curr);

        if (curr > fmax) {
            smax = fmax;
            fmax = curr;
        }
        else if (curr > smax && curr != fmax) {
            smax = curr;
        }
    }

    printf("%d %d", fmax, smax);

    return 0;
}
